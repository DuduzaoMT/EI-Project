<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_EnergyAnalytics" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collaboration_EnergyAnalytics">
    <bpmn:participant id="Participant_EnergyAnalytics" name="Energy Analytics (D4)" processRef="EnergyAnalyticsProcess" />
  </bpmn:collaboration>
  <bpmn:process id="EnergyAnalyticsProcess" name="Energy Analytics" isExecutable="true">
    <bpmn:laneSet id="LaneSet_EA">
      <bpmn:lane id="Lane_AnalyticsManager_EA" name="Analytics Manager">
        <bpmn:flowNodeRef>StartEvent_EA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_SelectZone_EA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_EA</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System_EA" name="VPPaaS System">
        <bpmn:flowNodeRef>ServiceTask_GetTelemetry_EA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_GetProsumers_EA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_GetGridCells_EA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_PublishAnalytics_EA</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_EA">
      <bpmn:outgoing>Flow_EA_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_SelectZone_EA" name="Select Zone for Energy Analytics">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_EA_1</bpmn:incoming>
      <bpmn:outgoing>Flow_EA_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_GetTelemetry_EA" name="Get Telemetry for Zone" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;http://KONG_ADDRESS:8000/telemetry/Telemetry/grid/&#34; + gridCellId" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusTelemetry: response.status,&#10;  telemetryData: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_EA_2</bpmn:incoming>
      <bpmn:outgoing>Flow_EA_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_GetProsumers_EA" name="Get Prosumers in Zone" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;http://KONG_ADDRESS:8000/prosumer/Prosumer?gridCellId=&#34; + gridCellId" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusProsumers: response.status,&#10;  prosumerList: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_EA_3</bpmn:incoming>
      <bpmn:outgoing>Flow_EA_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_GetGridCells_EA" name="Get Grid Cell Info" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="http://KONG_ADDRESS:8000/utility-operator/UtilityOperator/grid-cells" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusGridCells: response.status,&#10;  gridCells: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_EA_4</bpmn:incoming>
      <bpmn:outgoing>Flow_EA_5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_PublishAnalytics_EA" name="Publish Energy Analytics" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="http://KONG_ADDRESS:8000/energy-analytics/EnergyAnalytics/Publish" target="url" />
          <zeebe:input source="={&#10;  &#34;Content-Type&#34;: &#34;application/json&#34;,&#10;  &#34;accept&#34;: &#34;application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="={&#10;  &#34;gridCellId&#34;: gridCellId&#10;}" target="body" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusAnalytics: response.status,&#10;  analyticsResult: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_EA_5</bpmn:incoming>
      <bpmn:outgoing>Flow_EA_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_EA">
      <bpmn:incoming>Flow_EA_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_EA_1" sourceRef="StartEvent_EA" targetRef="UserTask_SelectZone_EA" />
    <bpmn:sequenceFlow id="Flow_EA_2" sourceRef="UserTask_SelectZone_EA" targetRef="ServiceTask_GetTelemetry_EA" />
    <bpmn:sequenceFlow id="Flow_EA_3" sourceRef="ServiceTask_GetTelemetry_EA" targetRef="ServiceTask_GetProsumers_EA" />
    <bpmn:sequenceFlow id="Flow_EA_4" sourceRef="ServiceTask_GetProsumers_EA" targetRef="ServiceTask_GetGridCells_EA" />
    <bpmn:sequenceFlow id="Flow_EA_5" sourceRef="ServiceTask_GetGridCells_EA" targetRef="ServiceTask_PublishAnalytics_EA" />
    <bpmn:sequenceFlow id="Flow_EA_6" sourceRef="ServiceTask_PublishAnalytics_EA" targetRef="EndEvent_EA" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_EA">
    <bpmndi:BPMNPlane id="BPMNPlane_EA" bpmnElement="Collaboration_EnergyAnalytics">
      <bpmndi:BPMNShape id="Participant_EnergyAnalytics_di" bpmnElement="Participant_EnergyAnalytics" isHorizontal="true">
        <dc:Bounds x="160" y="120" width="1080" height="340" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AnalyticsManager_EA_di" bpmnElement="Lane_AnalyticsManager_EA" isHorizontal="true">
        <dc:Bounds x="190" y="120" width="1050" height="170" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_System_EA_di" bpmnElement="Lane_System_EA" isHorizontal="true">
        <dc:Bounds x="190" y="290" width="1050" height="170" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_EA_di" bpmnElement="StartEvent_EA">
        <dc:Bounds x="241" y="187" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_SelectZone_EA_di" bpmnElement="UserTask_SelectZone_EA">
        <dc:Bounds x="325" y="165" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_GetTelemetry_EA_di" bpmnElement="ServiceTask_GetTelemetry_EA" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="475" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_GetProsumers_EA_di" bpmnElement="ServiceTask_GetProsumers_EA" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="635" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_GetGridCells_EA_di" bpmnElement="ServiceTask_GetGridCells_EA" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="795" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_PublishAnalytics_EA_di" bpmnElement="ServiceTask_PublishAnalytics_EA" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="955" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_EA_di" bpmnElement="EndEvent_EA">
        <dc:Bounds x="1107" y="187" width="36" height="36" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_EA_1_di" bpmnElement="Flow_EA_1">
        <di:waypoint x="277" y="205" />
        <di:waypoint x="325" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EA_2_di" bpmnElement="Flow_EA_2">
        <di:waypoint x="375" y="245" />
        <di:waypoint x="375" y="375" />
        <di:waypoint x="475" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EA_3_di" bpmnElement="Flow_EA_3">
        <di:waypoint x="575" y="375" />
        <di:waypoint x="635" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EA_4_di" bpmnElement="Flow_EA_4">
        <di:waypoint x="735" y="375" />
        <di:waypoint x="795" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EA_5_di" bpmnElement="Flow_EA_5">
        <di:waypoint x="895" y="375" />
        <di:waypoint x="955" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EA_6_di" bpmnElement="Flow_EA_6">
        <di:waypoint x="1055" y="375" />
        <di:waypoint x="1125" y="375" />
        <di:waypoint x="1125" y="223" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
