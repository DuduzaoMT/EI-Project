<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_GridBalancing" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collaboration_GridBalancing">
    <bpmn:participant id="Participant_GridBalancing" name="Grid Balancing Recommendation (D3)" processRef="GridBalancingProcess" />
  </bpmn:collaboration>
  <bpmn:process id="GridBalancingProcess" name="Grid Balancing Recommendation" isExecutable="true">
    <bpmn:laneSet id="LaneSet_GB">
      <bpmn:lane id="Lane_GridOperator_GB" name="Grid Operator">
        <bpmn:flowNodeRef>StartEvent_GB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_SelectZone_GB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_GB</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System_GB" name="VPPaaS System">
        <bpmn:flowNodeRef>ServiceTask_GetGridCells_GB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_GetTelemetry_GB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_GetProsumers_GB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_EmitGridBalancing_GB</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_GB">
      <bpmn:outgoing>Flow_GB_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_SelectZone_GB" name="Select Grid Zone for Balancing">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GB_1</bpmn:incoming>
      <bpmn:outgoing>Flow_GB_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_GetGridCells_GB" name="Get All Grid Cells" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="http://ec2-44-211-31-215.compute-1.amazonaws.com:8000/utility-operator/UtilityOperator/1/grid-cells" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusGridCells: response.status,&#10;  gridCells: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GB_2</bpmn:incoming>
      <bpmn:outgoing>Flow_GB_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_GetTelemetry_GB" name="Get Telemetry for Zone" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;http://ec2-44-211-31-215.compute-1.amazonaws.com:8000/telemetry/Telemetry/grid/&#34; + gridCellId" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusTelemetry: response.status,&#10;  telemetryData: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GB_3</bpmn:incoming>
      <bpmn:outgoing>Flow_GB_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_GetProsumers_GB" name="Get Prosumers in Zone" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;http://ec2-44-211-31-215.compute-1.amazonaws.com:8000/prosumer/Prosumer?gridCellId=&#34; + gridCellId" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusProsumers: response.status,&#10;  prosumerList: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GB_4</bpmn:incoming>
      <bpmn:outgoing>Flow_GB_5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_EmitGridBalancing_GB" name="Emit Grid Balancing Recommendation" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="http://ec2-44-211-31-215.compute-1.amazonaws.com:8000/grid-balancing/GridBalancing/Emit" target="url" />
          <zeebe:input source="={&#10;  &#34;Content-Type&#34;: &#34;application/json&#34;,&#10;  &#34;accept&#34;: &#34;application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="={&#10;  &#34;source_grid_cell&#34;: gridCellId,&#10;  &#34;target_grid_cell&#34;: gridCellId,&#10;  &#34;recommended_action&#34;: &#34;DISCHARGE&#34;,&#10;  &#34;power_kw&#34;: sum(telemetryData.Available_Energy)&#10;}" target="body" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  StatusGridBalancing: response.status,&#10;  balancingRecommendation: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GB_5</bpmn:incoming>
      <bpmn:outgoing>Flow_GB_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_GB">
      <bpmn:incoming>Flow_GB_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_GB_1" sourceRef="StartEvent_GB" targetRef="UserTask_SelectZone_GB" />
    <bpmn:sequenceFlow id="Flow_GB_2" sourceRef="UserTask_SelectZone_GB" targetRef="ServiceTask_GetGridCells_GB" />
    <bpmn:sequenceFlow id="Flow_GB_3" sourceRef="ServiceTask_GetGridCells_GB" targetRef="ServiceTask_GetTelemetry_GB" />
    <bpmn:sequenceFlow id="Flow_GB_4" sourceRef="ServiceTask_GetTelemetry_GB" targetRef="ServiceTask_GetProsumers_GB" />
    <bpmn:sequenceFlow id="Flow_GB_5" sourceRef="ServiceTask_GetProsumers_GB" targetRef="ServiceTask_EmitGridBalancing_GB" />
    <bpmn:sequenceFlow id="Flow_GB_6" sourceRef="ServiceTask_EmitGridBalancing_GB" targetRef="EndEvent_GB" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_GB">
    <bpmndi:BPMNPlane id="BPMNPlane_GB" bpmnElement="Collaboration_GridBalancing">
      <bpmndi:BPMNShape id="Participant_GridBalancing_di" bpmnElement="Participant_GridBalancing" isHorizontal="true">
        <dc:Bounds x="160" y="120" width="1080" height="340" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_GridOperator_GB_di" bpmnElement="Lane_GridOperator_GB" isHorizontal="true">
        <dc:Bounds x="190" y="120" width="1050" height="170" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_System_GB_di" bpmnElement="Lane_System_GB" isHorizontal="true">
        <dc:Bounds x="190" y="290" width="1050" height="170" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_GB_di" bpmnElement="StartEvent_GB">
        <dc:Bounds x="241" y="187" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_SelectZone_GB_di" bpmnElement="UserTask_SelectZone_GB">
        <dc:Bounds x="325" y="165" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_GetGridCells_GB_di" bpmnElement="ServiceTask_GetGridCells_GB" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="475" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_GetTelemetry_GB_di" bpmnElement="ServiceTask_GetTelemetry_GB" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="635" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_GetProsumers_GB_di" bpmnElement="ServiceTask_GetProsumers_GB" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="795" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_EmitGridBalancing_GB_di" bpmnElement="ServiceTask_EmitGridBalancing_GB" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="955" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_GB_di" bpmnElement="EndEvent_GB">
        <dc:Bounds x="1107" y="187" width="36" height="36" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_GB_1_di" bpmnElement="Flow_GB_1">
        <di:waypoint x="277" y="205" />
        <di:waypoint x="325" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GB_2_di" bpmnElement="Flow_GB_2">
        <di:waypoint x="375" y="245" />
        <di:waypoint x="375" y="375" />
        <di:waypoint x="475" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GB_3_di" bpmnElement="Flow_GB_3">
        <di:waypoint x="575" y="375" />
        <di:waypoint x="635" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GB_4_di" bpmnElement="Flow_GB_4">
        <di:waypoint x="735" y="375" />
        <di:waypoint x="795" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GB_5_di" bpmnElement="Flow_GB_5">
        <di:waypoint x="895" y="375" />
        <di:waypoint x="955" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GB_6_di" bpmnElement="Flow_GB_6">
        <di:waypoint x="1055" y="375" />
        <di:waypoint x="1125" y="375" />
        <di:waypoint x="1125" y="223" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
